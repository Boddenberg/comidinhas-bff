APP_NAME=Comidinhas BFF
APP_ENV=local
APP_VERSION=0.1.0
WEB_APP_BASE_URL=https://comidinhas-web-production.up.railway.app
WEB_GROUP_INVITE_PATH=/entrar
LOG_LEVEL=INFO
LOG_HTTPX_LEVEL=WARNING
LOG_UVICORN_ACCESS_LEVEL=INFO
LOG_REQUEST_BODY=false
LOG_BODY_MAX_CHARS=2000

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_DEFAULT_LANGUAGE_CODE=pt-BR
GOOGLE_PLACES_DEFAULT_REGION_CODE=BR
GOOGLE_PLACES_MAX_PHOTOS_PER_PLACE=10

GUIAS_AI_ENABLED=true
GUIAS_AI_CHAT_MODEL=gpt-4o-mini
GUIAS_AI_CLASSIFIER_MODEL=gpt-4o-mini
GUIAS_AI_EXTRACTOR_MODEL=gpt-4o-mini
GUIAS_AI_TEXT_MIN_CHARS=80
GUIAS_AI_TEXT_MAX_CHARS=80000
GUIAS_AI_MAX_ITEMS_PER_GUIDE=80
GUIAS_AI_MIN_ITEMS_TO_CREATE_GUIDE=3
GUIAS_AI_MAX_PLACES_LOOKUPS_PER_JOB=80
GUIAS_AI_PLACES_CONCURRENCY=4
GUIAS_AI_CLASSIFIER_MIN_CONFIDENCE=0.4
GUIAS_AI_MATCH_STRONG_SCORE=0.82
GUIAS_AI_MATCH_WEAK_SCORE=0.55
GUIAS_AI_STEP_MAX_ATTEMPTS=3
GUIAS_AI_JOB_MAX_SECONDS=900
GUIAS_AI_PROMPT_VERSION=1.0.0

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_PROFILE_BUCKET=profile-photos
SUPABASE_PROFILE_PHOTO_MAX_BYTES=2097152
SUPABASE_GROUP_BUCKET=group-photos
SUPABASE_GROUP_PHOTO_MAX_BYTES=2097152

INFOBIP_BASE_URL=https://55e4jx.api.infobip.com
INFOBIP_API_KEY=
INFOBIP_WHATSAPP_FROM=
INFOBIP_DEFAULT_TEMPLATE_NAME=test_whatsapp_template_en
INFOBIP_DEFAULT_LANGUAGE=en
